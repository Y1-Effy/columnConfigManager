# MongoDB 接続 URI
# ローカル開発:  mongodb://localhost:27017/column-config-manager
# MongoDB Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/column-config-manager
MONGO_URI=mongodb://localhost:27017/column-config-manager

# サーバーポート（デフォルト: 3000）
PORT=3000

# 実行環境（development | production）
NODE_ENV=development
