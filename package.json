  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.0.0",
    "supertest": "^7.0.0"
